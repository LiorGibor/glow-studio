# Backend Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME="Glow Studio"
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ADMIN_EMAIL=admin@glowstudio.com
ADMIN_PASSWORD=admin123

# Database
DATABASE_URL=sqlite:///./glow_studio.db

# CORS
FRONTEND_URL=http://localhost:5173

# Notifications - Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notifications - Email SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Cloudinary (optional, for production image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
